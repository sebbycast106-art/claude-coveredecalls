# ── covered-calls-app environment ───────────────────────────────────────────
# Copy to .env.local for local dev (never commit real secrets).

# Signing secret for the login JWT cookie (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# bcrypt hash of the shared viewing password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# If UNSET in local dev, any password is accepted (convenience only).
APP_PASSWORD_HASH=

# Shared secret the Python engine must present to POST /api/push.
# Must match the bot's SCHEDULER_SECRET GitHub Actions secret.
SCHEDULER_SECRET=change-me-to-match-the-bot

# SQLite database location. On Railway, point this at a mounted volume so the
# pushed data + premium ledger survive redeploys, e.g. file:/data/app.db
DATABASE_URL=file:./app.db
